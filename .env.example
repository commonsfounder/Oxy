# ── Required ──────────────────────────────────────────────

# Supabase (database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGc...

# Google Gemini (conversation AI + TTS + speech-to-text)
GEMINI_API_KEY=...
# Optional model overrides for Oxy's chat brain
# OXY_REASONING_MODEL=gemini-3-flash-preview
# OXY_FAST_MODEL=gemini-3-flash-preview
# OXY_LIVE_MODEL=gemini-live-2.5-flash-preview
# Experimental: route the main chat brain to a second provider for A/B latency tests.
# Default is gemini; production is unaffected unless this is set.
# OXY_BRAIN_PROVIDER=groq
# OXY_GROQ_MODEL=llama-3.3-70b-versatile   # or llama-3.1-8b-instant for max speed
# GROQ_API_KEY=...
# GOOGLE_GENAI_USE_ENTERPRISE=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Session signing secret for per-user auth tokens
OXY_SESSION_SECRET=replace-with-a-long-random-secret

# ── Optional ──────────────────────────────────────────────

# Timezone (defaults to Europe/London)
# TIMEZONE=Europe/London

# App URL (used for OAuth redirects and CORS)
# APP_URL=https://your-app-xxxxx-ew.a.run.app

# Google OAuth (Gmail + Calendar connector)
# GMAIL_CLIENT_ID=...
# GMAIL_CLIENT_SECRET=...
# GMAIL_REFRESH_TOKEN=...

# Telegram User API (messaging connector)
# TELEGRAM_API_ID=...
# TELEGRAM_API_HASH=...

# Twilio (SMS/calls via MCP server)
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1234567890

# Spotify (music via MCP server)
# SPOTIFY_CLIENT_ID=...
# SPOTIFY_CLIENT_SECRET=...
# SPOTIFY_REFRESH_TOKEN=...

# Firecrawl (flights + activities search — firecrawl.dev)
# FIRECRAWL_API_KEY=fc-...

# TransportAPI (UK train times connector)
# TRANSPORT_API_APP_ID=...
# TRANSPORT_API_APP_KEY=...

# Google Maps (geocoding + Places lookup for Uber/local connector)
# GOOGLE_MAPS_API_KEY=...

# Apple Push Notification service (proactive iOS briefings)
# APNS_KEY_ID=...
# APNS_TEAM_ID=...
# APNS_BUNDLE_ID=ai.oxy.app
# APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APNS_USE_SANDBOX=true
# Optional: require Cloud Scheduler to send this via x-proactive-secret or ?secret=
# PROACTIVE_SWEEP_SECRET=...

# Home Assistant (smart home via MCP server)
# HOME_ASSISTANT_URL=http://homeassistant.local:8123
# HOME_ASSISTANT_TOKEN=...

# Error Monitoring (get DSN from sentry.io - free tier available)
# SENTRY_DSN=

# Debug/Admin endpoints protection
# DEBUG_SECRET=

# Transactional Email (get API key from resend.com)
# RESEND_API_KEY=
# EMAIL_FROM=Oxy <noreply@oxy.app>

# Analytics (get key from posthog.com/eu - EU hosting for GDPR)
# POSTHOG_KEY=

# Session security - increment this to invalidate ALL user sessions on next deploy
SESSION_SECRET_ROTATION_VERSION=1

# --- Browser task: managed (residential) browser for bot-walled sites ---------------------
# Local Chromium is free but runs on this box's IP; on a datacenter IP (Cloud Run) anti-bot
# walls block ~a third of sites (Next, H&M, Argos, Nike, Just Eat). A managed scraping browser
# routes through residential IPs + real fingerprints to clear them. It is METERED, so by
# default we ONLY route the known bot-walled hosts through it — everything else stays local.
#
# Set to your provider's CDP endpoint to enable. Examples:
#   Bright Data:  wss://brd-customer-<id>-zone-<zone>:<pass>@brd.superproxy.io:9222
#   Browserbase:  wss://connect.browserbase.com?apiKey=<key>   (or per-session connect URL)
# BROWSER_REMOTE_ENDPOINT=
# BROWSER_REMOTE_ALWAYS=false                 # true = route EVERY task through the managed browser (costly)
# BROWSER_REMOTE_HOSTS=next.co.uk,hm.com      # override the default bot-wall host list (comma-separated)
# OXY_BROWSER_REMOTE_CONNECT_TIMEOUT_MS=15000 # bail to local if the endpoint doesn't answer in time
