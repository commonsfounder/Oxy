{
  "functions": {
    "server.js": {
      "includeFiles": "index.html",
      "memory": 512,
      "maxDuration": 60
    },
    "api/proxy.js": {
      "memory": 512,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/proxy", "destination": "/api/proxy.js" },
    { "source": "/(.*)", "destination": "/server.js" }
  ]
}
