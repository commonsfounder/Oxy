{
  "name": "oxy",
  "version": "1.0.0",
  "description": "Oxy — AI-powered personal assistant",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test test/smoke/*.test.js",
    "smoke": "node --test test/smoke/*.test.js",
    "brain:evals": "node --test test/smoke/brain-evals.test.js",
    "latency": "node test/bench/latency.js",
