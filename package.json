    "proactive:job": "node proactive-job.js",
    "retention:job": "node retention-job.js"
  },
  "dependencies": {
    "@google/genai": "^2.2.0",
    "@google/generative-ai": "^0.12.0",
    "@sentry/node": "^8.55.2",
    "@supabase/supabase-js": "^2.49.0",
    "archiver": "^7.0.1",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "multer": "^1.4.5-lts.2",
    "playwright": "^1.60.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "telegram": "^2.26.22",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
